{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run vercel:build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/config.js",
      "destination": "/api/index.js"
    },
    {
      "source": "/vendor/supabase.js",
      "destination": "/api/index.js"
    }
  ]
}
