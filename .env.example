SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
APP_URL=http://localhost:3000
APP_SECRET=replace-with-local-development-secret

# Optional: approval notification email for Google access requests.
# Use either a webhook that sends email:
APPROVAL_EMAIL_WEBHOOK_URL=
APPROVAL_EMAIL_WEBHOOK_TOKEN=
# Or Resend:
RESEND_API_KEY=
APPROVAL_EMAIL_FROM="ApecGlobal Manager <no-reply@example.com>"
