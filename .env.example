SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
APP_SECRET=replace-with-local-development-secret
APP_ALLOWED_ORIGINS=http://127.0.0.1:3000,https://localhost,capacitor://localhost,https://your-vercel-app.vercel.app

# Initial local admin login is admin / admin123.
# Change the password after first login.
ADMIN_USERNAME=admin

# Optional: approval notification email for Google access requests.
# Use either a webhook that sends email:
APPROVAL_EMAIL_WEBHOOK_URL=
APPROVAL_EMAIL_WEBHOOK_TOKEN=
# Or Resend:
RESEND_API_KEY=
APPROVAL_EMAIL_FROM="ApecGlobal Manager <no-reply@example.com>"
