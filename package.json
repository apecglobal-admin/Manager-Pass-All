{
  "name": "apecglobal-manager",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "main": "desktop/main.cjs",
  "engines": {
    "node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apecglobal-admin/Manager-Pass-All.git"
  },
  "scripts": {
    "build": "npm run vercel:build",
    "vercel:build": "node scripts/vercel-build.js",
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "desktop": "electron .",
    "package:win": "electron-builder --win nsis portable",
    "package:win:portable": "electron-builder --win portable",
    "publish:win": "electron-builder --win nsis --publish always",
    "cap:sync": "cap sync",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "test": "node --test",
    "clean": "node clean.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@supabase/supabase-js": "^2.48.1",
    "electron-updater": "^6.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.apecglobal.manager",
    "productName": "ApecGlobal Manager",
    "publish": [
      {
        "provider": "github",
        "owner": "apecglobal-admin",
        "repo": "Manager-Pass-All",
        "releaseType": "release"
      }
    ],
    "files": [
      "build/**/*",
      "desktop/**/*",
      "src/**/*",
      "public/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "ApecGlobal-Manager-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ApecGlobal Manager"
    },
    "portable": {
      "artifactName": "ApecGlobal-Manager-Portable-${version}.${ext}"
    }
  }
}